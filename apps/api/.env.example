# Database
DATABASE_URL="postgres://postgres:neolounge@127.0.0.1:5432/neolounge?schema=public"

# Africa's Talking M-Pesa (Stage 7)
AT_API_KEY=your_at_api_key_here
AT_USERNAME=your_at_username_here
AT_ENVIRONMENT=sandbox
AT_SHORTCODE=Neo Lounge

# Mock controls (set to "true" to use mock implementations)
USE_MOCK_PAYMENTS=true
USE_MOCK_HARDWARE=true
MOCK_PAYMENT_SHOULD_FAIL=false

# API base URL (used by mock payment auto-callback)
API_BASE_URL=http://localhost:3000
